{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure (Release)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "release"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "debug"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build/release"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build/release", "--clean-first"],
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "ctest",
            "args": ["--test-dir", "build/release", "--output-on-failure"],
            "group": "test",
            "problemMatcher": []
        }
    ]
}
