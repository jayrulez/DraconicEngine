{
    // CMake Tools - use the release preset (Ninja + clang; works on Linux and Windows)
    "cmake.configureOnOpen": false,
    "cmake.configureSettings": {},

    // clangd
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build/release",
        "--background-index",
        "--clang-tidy=false",
        "--header-insertion=never"
    ],

    // Disable the Microsoft C/C++ IntelliSense in favor of clangd
    "C_Cpp.intelliSenseEngine": "disabled",

    // Files
    "files.associations": {
        "*.cppm": "cpp"
    },
    "files.exclude": {
        "build": true,
        ".claude": true
    },

    "editor.formatOnSave": false
}
